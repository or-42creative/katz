# ===== Database (PostgreSQL) =====
# Vercel Postgres / Neon / Supabase connection string.
# Use the POOLED connection string for serverless.
DATABASE_URL="postgresql://user:password@host:5432/katz?sslmode=require"

# ===== Auth.js (NextAuth v5) =====
# Generate with:  npx auth secret
AUTH_SECRET="replace-me-with-a-long-random-string"

# Required on Vercel / any non-localhost host
AUTH_TRUST_HOST=true

# ===== Google OAuth =====
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:  https://YOUR-DOMAIN/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ===== App config =====
# Restrict sign-in to a single email domain (internal use).
# Leave empty to allow any Google account.
ALLOWED_EMAIL_DOMAIN="42creative.co.il"

# The super-admin email — always granted ADMIN role.
SUPER_ADMIN_EMAIL="or@42creative.co.il"
